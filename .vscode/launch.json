{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (Compile TS Only)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/src/AutoContext.VsCode"],
      "outFiles": ["${workspaceFolder}/src/AutoContext.VsCode/dist/**/*.js"],
      "preLaunchTask": "compile-ts-only"
    },
    {
      "name": "Run Extension (Full Build)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/src/AutoContext.VsCode"],
      "outFiles": ["${workspaceFolder}/src/AutoContext.VsCode/dist/**/*.js"],
      "preLaunchTask": "local-package"
    }
  ]
}
