# Set default behavior to automatically normalize line endings.
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.cs text eol=lf
*.csx text eol=lf
*.razor text eol=lf
*.xaml text eol=lf
*.xml text eol=lf
*.config text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.csproj text eol=lf
*.sln text eol=lf

# Declare files that will always have CRLF line endings on checkout.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.bmp binary
*.tiff binary
*.exe binary
*.dll binary
*.pdb binary
*.zip binary
*.7z binary
*.rar binary
*.tar binary
*.gz binary
*.bz2 binary
*.xz binary
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
*.snk binary
*.pfx binary
