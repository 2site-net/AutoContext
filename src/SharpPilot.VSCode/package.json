  "scripts": {
    "vscode:prepublish": "node -e \"if(!process.env.SHARPPILOT_VSCE_BYPASS){console.error('Do not run vsce package directly. Use: ./build.ps1 Package');process.exit(1)}\"",
    "compile": "pwsh ../../build.ps1 Compile TS",
    "watch": "tsc -watch -p ./tsconfig.build.json",
    "test": "pwsh ../../build.ps1 Test TS",
    "test:smoke": "npm run compile && tsc -p tests/smoke-tests/tsconfig.json && node -e \"require('fs').writeFileSync('out/tests/smoke-tests/package.json','{\\\"type\\\":\\\"commonjs\\\"}')\" && vscode-test --config tests/.vscode-test.mjs"
  },
