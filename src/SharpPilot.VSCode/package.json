    "walkthroughs": [
      {
        "id": "sharppilot.getStarted",
        "title": "Get Started with SharpPilot",
        "description": "Learn how SharpPilot enhances GitHub Copilot with curated instructions and MCP tools.",
        "steps": [
          {
            "id": "sharppilot.welcome",
            "title": "Welcome to SharpPilot",
            "description": "Discover how SharpPilot elevates code quality with curated instructions and model-invokable tools.",
            "media": {
              "markdown": "walkthroughs/welcome.md"
            }
          },
          {
            "id": "sharppilot.instructions",
            "title": "Chat Instructions",
            "description": "Enable instruction sets that guide Copilot's responses for your tech stack.\n[Open Instructions Panel](command:sharppilot.instructionsView.focus)",
            "media": {
              "markdown": "walkthroughs/instructions.md"
            },
            "completionEvents": [
              "onView:sharppilot.instructionsView"
            ]
          },
          {
            "id": "sharppilot.tools",
            "title": "MCP Tools",
            "description": "Enable quality-assurance tools that Copilot can call in agent mode.\n[Open Tools Panel](command:sharppilot.toolsView.focus)",
            "media": {
              "markdown": "walkthroughs/tools.md"
            },
            "completionEvents": [
              "onView:sharppilot.toolsView"
            ]
          },
          {
            "id": "sharppilot.autoConfigure",
            "title": "Auto Configure",
            "description": "Let SharpPilot detect your workspace and enable the right instructions and tools.\n[Auto Configure](command:sharppilot.autoConfigure)",
            "media": {
              "markdown": "walkthroughs/auto-configure.md"
            },
            "completionEvents": [
              "onCommand:sharppilot.autoConfigure"
            ]
          },
          {
            "id": "sharppilot.exportAndBrowse",
            "title": "Export & Browse",
            "description": "Export instruction files to your repository using the sidebar panel.\n[Open Instructions Panel](command:sharppilot.instructionsView.focus)",
            "media": {
              "markdown": "walkthroughs/export-and-browse.md"
            },
            "completionEvents": [
              "onCommand:sharppilot.enterExportMode"
            ]
          }
        ]
      }
    ],
