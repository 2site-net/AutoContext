{
  "name": "sharppilot",
  "displayName": "SharpPilot",
  "description": "SharpPilot is a quality assurance extension for Visual Studio Code that leverages an MCP server to enable model-invokable tools and curated, configurable instructions—elevating code quality, workflows, and overall developer productivity with Copilot.",
  "version": "0.5.0",
  "publisher": "2site-net",
  "license": "AGPL-3.0-only",
  "author": {
    "name": "Eyal Alon",
    "email": "sharppilot@2site.net",
    "url": "https://github.com/iam3yal"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/2site-net/SharpPilot"
  },
  "bugs": {
    "url": "https://github.com/2site-net/SharpPilot/issues"
  },
  "icon": "resources/logo.png",
  "type": "module",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "sharpPilotProvider",
        "label": "SharpPilot Servers"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sharppilot",
          "title": "SharpPilot",
          "icon": "resources/sidebar.svg"
        }
      ]
    },
    "views": {
      "sharppilot": [
        {
          "id": "sharppilot.instructionsView",
          "name": "Instructions",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "sharppilot.toolsView",
          "name": "MCP Tools",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "commands": [
      {
        "command": "sharppilot.autoConfigure",
        "title": "Auto Configure",
        "category": "SharpPilot"
      },
      {
        "command": "sharppilot.toggleInstruction",
        "title": "Toggle Instruction",
        "category": "SharpPilot"
      },
      {
        "command": "sharppilot.resetInstructions",
        "title": "Reset Instructions",
        "category": "SharpPilot"
      },
      {
        "command": "sharppilot.enableInstruction",
        "title": "Enable Instruction",
        "category": "SharpPilot",
        "icon": "$(check)"
      },
      {
        "command": "sharppilot.disableInstruction",
        "title": "Disable Instruction",
        "category": "SharpPilot",
        "icon": "$(close)"
      },
      {
        "command": "sharppilot.enterExportMode",
        "title": "Export Instructions",
        "category": "SharpPilot",
        "icon": "$(export)"
      },
      {
        "command": "sharppilot.confirmExport",
        "title": "Confirm Export",
        "category": "SharpPilot",
        "icon": "$(check)"
      },
      {
        "command": "sharppilot.cancelExport",
        "title": "Cancel Export",
        "category": "SharpPilot",
        "icon": "$(close)"
      },
      {
        "command": "sharppilot.deleteOverride",
        "title": "Delete Override",
        "category": "SharpPilot",
        "icon": "$(trash)"
      },
      {
        "command": "sharppilot.showOriginal",
        "title": "Show Original",
        "category": "SharpPilot",
        "icon": "$(eye)"
      },
      {
        "command": "sharppilot.showNotDetected",
        "title": "Show Not Detected",
        "category": "SharpPilot",
        "icon": "$(eye)"
      },
      {
        "command": "sharppilot.hideNotDetected",
        "title": "Hide Not Detected",
        "category": "SharpPilot",
        "icon": "$(eye-closed)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "sharppilot.toggleInstruction",
          "when": "false"
        },
        {
          "command": "sharppilot.resetInstructions",
          "when": "false"
        },
        {
          "command": "sharppilot.enableInstruction",
          "when": "false"
        },
        {
          "command": "sharppilot.disableInstruction",
          "when": "false"
        },
        {
          "command": "sharppilot.enterExportMode",
          "when": "false"
        },
        {
          "command": "sharppilot.confirmExport",
          "when": "false"
        },
        {
          "command": "sharppilot.cancelExport",
          "when": "false"
        },
        {
          "command": "sharppilot.deleteOverride",
          "when": "false"
        },
        {
          "command": "sharppilot.showOriginal",
          "when": "false"
        },
        {
          "command": "sharppilot.showNotDetected",
          "when": "false"
        },
        {
          "command": "sharppilot.hideNotDetected",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "sharppilot.hideNotDetected",
          "when": "(view == 'sharppilot.instructionsView' || view == 'sharppilot.toolsView') && sharppilot.showNotDetected"
        },
        {
          "command": "sharppilot.showNotDetected",
          "when": "(view == 'sharppilot.instructionsView' || view == 'sharppilot.toolsView') && !sharppilot.showNotDetected"
        },
        {
          "command": "sharppilot.enterExportMode",
          "when": "view == 'sharppilot.instructionsView' && !sharppilot.exportMode",
          "group": "navigation@2"
        },
        {
          "command": "sharppilot.confirmExport",
          "when": "view == 'sharppilot.instructionsView' && sharppilot.exportMode",
          "group": "navigation@2"
        },
        {
          "command": "sharppilot.cancelExport",
          "when": "view == 'sharppilot.instructionsView' && sharppilot.exportMode",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "sharppilot.enableInstruction",
          "when": "viewItem == 'instruction.disabled' && !sharppilot.exportMode",
          "group": "inline"
        },
        {
          "command": "sharppilot.disableInstruction",
          "when": "viewItem == 'instruction.enabled' && !sharppilot.exportMode",
          "group": "inline"
        },
        {
          "command": "sharppilot.showOriginal",
          "when": "viewItem == 'instruction.overridden' && !sharppilot.exportMode",
          "group": "inline@1"
        },
        {
          "command": "sharppilot.deleteOverride",
          "when": "viewItem == 'instruction.overridden' && !sharppilot.exportMode",
          "group": "inline@2"
        }
      ]
    },
    "chatInstructions": [
      {
        "path": "./instructions/copilot.instructions.md"
      },
      {
        "path": "./instructions/.generated/code-review.instructions.md",
        "when": "config.sharppilot.instructions.codeReview && !sharppilot.override.codeReview"
      },
      {
        "path": "./instructions/.generated/design-principles.instructions.md",
        "when": "config.sharppilot.instructions.designPrinciples && !sharppilot.override.designPrinciples"
      },
      {
        "path": "./instructions/.generated/rest-api-design.instructions.md",
