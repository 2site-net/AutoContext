{
  "name": "sharp-pilot",
  "displayName": "SharpPilot",
  "description": "SharpPilot is a development quality toolkit for GitHub Copilot, providing a curated set of tools and guidelines to improve code quality and the overall development workflow.",
  "version": "0.5.0",
  "publisher": "2site-net",
  "license": "Apache-2.0",
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "sharpPilotProvider",
        "label": "SharpPilot Servers"
      }
    ],
    "commands": [
      {
        "command": "sharp-pilot.toggleInstructions",
        "title": "Toggle Instructions",
        "category": "SharpPilot"
      },
      {
        "command": "sharp-pilot.exportInstructions",
        "title": "Export Instructions",
        "category": "SharpPilot"
      },
      {
        "command": "sharp-pilot.browseInstructions",
        "title": "Browse Instructions",
        "category": "SharpPilot"
      }
    ],
    "chatInstructions": [
      {
        "path": "./instructions/copilot.instructions.md",
        "when": "config.sharp-pilot.instructions.copilot && !sharp-pilot.override.copilot"
      },
      {
        "path": "./instructions/design-principles.instructions.md",
        "when": "config.sharp-pilot.instructions.designPrinciples && !sharp-pilot.override.designPrinciples"
      },
      {
        "path": "./instructions/rest-api-design.instructions.md",
        "when": "config.sharp-pilot.instructions.restApiDesign && !sharp-pilot.override.restApiDesign"
      },
      {
        "path": "./instructions/dotnet-aspnetcore.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.aspnetCore && sharp-pilot.workspace.hasAspNetCore && !sharp-pilot.override.dotnet.aspnetCore"
      },
      {
        "path": "./instructions/dotnet-async-await.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.asyncAwait && sharp-pilot.workspace.hasDotnet && !sharp-pilot.override.dotnet.asyncAwait"
      },
      {
        "path": "./instructions/dotnet-blazor.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.blazor && sharp-pilot.workspace.hasBlazor && !sharp-pilot.override.dotnet.blazor"
      },
      {
        "path": "./instructions/dotnet-coding-standards.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.codingStandards && sharp-pilot.workspace.hasDotnet && !sharp-pilot.override.dotnet.codingStandards"
      },
      {
        "path": "./instructions/dotnet-debugging.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.debugging && sharp-pilot.workspace.hasDotnet && !sharp-pilot.override.dotnet.debugging"
      },
      {
        "path": "./instructions/dotnet-dapper.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.dapper && sharp-pilot.workspace.hasDapper && !sharp-pilot.override.dotnet.dapper"
      },
      {
        "path": "./instructions/dotnet-entity-framework-core.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.entityFrameworkCore && sharp-pilot.workspace.hasEntityFrameworkCore && !sharp-pilot.override.dotnet.entityFrameworkCore"
      },
      {
        "path": "./instructions/dotnet-nuget.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.nuget && sharp-pilot.workspace.hasDotnet && !sharp-pilot.override.dotnet.nuget"
      },
      {
        "path": "./instructions/dotnet-performance-memory.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.performanceMemory && sharp-pilot.workspace.hasDotnet && !sharp-pilot.override.dotnet.performanceMemory"
      },
      {
        "path": "./instructions/dotnet-postgresql.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.postgresql && sharp-pilot.workspace.hasPostgres && !sharp-pilot.override.dotnet.postgresql"
      },
      {
        "path": "./instructions/dotnet-razor.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.razor && sharp-pilot.workspace.hasBlazor && !sharp-pilot.override.dotnet.razor"
      },
      {
        "path": "./instructions/dotnet-sql-server.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.sqlServer && sharp-pilot.workspace.hasSqlServer && !sharp-pilot.override.dotnet.sqlServer"
      },
      {
        "path": "./instructions/dotnet-testing.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.testing && sharp-pilot.workspace.hasDotnet && !sharp-pilot.override.dotnet.testing"
      },
      {
        "path": "./instructions/dotnet-maui.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.maui && sharp-pilot.workspace.hasMaui && !sharp-pilot.override.dotnet.maui"
      },
      {
        "path": "./instructions/dotnet-mongodb.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.mongodb && sharp-pilot.workspace.hasMongodb && !sharp-pilot.override.dotnet.mongodb"
      },
      {
        "path": "./instructions/dotnet-mysql.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.mysql && sharp-pilot.workspace.hasMysql && !sharp-pilot.override.dotnet.mysql"
      },
      {
        "path": "./instructions/dotnet-oracle.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.oracle && sharp-pilot.workspace.hasOracle && !sharp-pilot.override.dotnet.oracle"
      },
      {
        "path": "./instructions/dotnet-sqlite.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.sqlite && sharp-pilot.workspace.hasSqlite && !sharp-pilot.override.dotnet.sqlite"
      },
      {
        "path": "./instructions/dotnet-unity.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.unity && sharp-pilot.workspace.hasUnity && !sharp-pilot.override.dotnet.unity"
      },
      {
        "path": "./instructions/dotnet-winforms.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.winForms && sharp-pilot.workspace.hasWinForms && !sharp-pilot.override.dotnet.winForms"
      },
      {
        "path": "./instructions/dotnet-wpf.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.wpf && sharp-pilot.workspace.hasWpf && !sharp-pilot.override.dotnet.wpf"
      },
      {
        "path": "./instructions/dotnet-xunit.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.xunit && sharp-pilot.workspace.hasXunit && !sharp-pilot.override.dotnet.xunit"
      },
      {
        "path": "./instructions/dotnet-csharp-coding-style.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.csharp.codingStyle && sharp-pilot.workspace.hasDotnet && !sharp-pilot.override.dotnet.csharp.codingStyle"
      },
      {
        "path": "./instructions/dotnet-fsharp-coding-style.instructions.md",
        "when": "config.sharp-pilot.instructions.dotnet.fsharp.codingStyle && sharp-pilot.workspace.hasFsharp && !sharp-pilot.override.dotnet.fsharp.codingStyle"
      },
      {
        "path": "./instructions/git-commit-format.instructions.md",
        "when": "config.sharp-pilot.instructions.git.commitFormat && sharp-pilot.workspace.hasGit && !sharp-pilot.override.git.commitFormat"
      },
      {
        "path": "./instructions/web-angular.instructions.md",
        "when": "config.sharp-pilot.instructions.web.angular && sharp-pilot.workspace.hasAngular && !sharp-pilot.override.web.angular"
      },
      {
        "path": "./instructions/web-css.instructions.md",
        "when": "config.sharp-pilot.instructions.web.css && sharp-pilot.workspace.hasCss && !sharp-pilot.override.web.css"
      },
      {
        "path": "./instructions/web-html.instructions.md",
        "when": "config.sharp-pilot.instructions.web.html && sharp-pilot.workspace.hasHtml && !sharp-pilot.override.web.html"
      },
      {
        "path": "./instructions/web-javascript.instructions.md",
        "when": "config.sharp-pilot.instructions.web.javascript && (sharp-pilot.workspace.hasJavaScript || sharp-pilot.workspace.hasTypeScript) && !sharp-pilot.override.web.javascript"
      },
      {
        "path": "./instructions/web-react.instructions.md",
        "when": "config.sharp-pilot.instructions.web.react && sharp-pilot.workspace.hasReact && !sharp-pilot.override.web.react"
      },
      {
        "path": "./instructions/web-svelte.instructions.md",
        "when": "config.sharp-pilot.instructions.web.svelte && sharp-pilot.workspace.hasSvelte && !sharp-pilot.override.web.svelte"
      },
      {
        "path": "./instructions/web-typescript.instructions.md",
        "when": "config.sharp-pilot.instructions.web.typescript && sharp-pilot.workspace.hasTypeScript && !sharp-pilot.override.web.typescript"
      },
      {
        "path": "./instructions/web-vue.instructions.md",
        "when": "config.sharp-pilot.instructions.web.vue && sharp-pilot.workspace.hasVue && !sharp-pilot.override.web.vue"
      }
    ],
    "configuration": {
      "title": "SharpPilot",
      "properties": {
        "sharp-pilot.instructions.copilot": {
          "type": "boolean",
          "default": true,
          "description": "Enable Copilot behavior rules and rule precedence."
        },
        "sharp-pilot.instructions.designPrinciples": {
          "type": "boolean",
          "default": true,
          "description": "Enable design principles (SOLID, DI, composition, separation of concerns, structured logging)."
        },
        "sharp-pilot.instructions.restApiDesign": {
          "type": "boolean",
          "default": true,
          "description": "Enable REST API design guidelines (resource naming, HTTP methods, status codes, pagination, error responses, versioning)."
        },
        "sharp-pilot.instructions.dotnet.aspnetCore": {
          "type": "boolean",
          "default": true,
          "description": "Enable ASP.NET Core Web API guidelines (middleware, routing, error handling, auth)."
        },
        "sharp-pilot.instructions.dotnet.asyncAwait": {
          "type": "boolean",
          "default": true,
          "description": "Enable async/await pattern guidelines for .NET code."
        },
        "sharp-pilot.instructions.dotnet.blazor": {
          "type": "boolean",
          "default": true,
          "description": "Enable Blazor component guidelines for Razor files."
        },
        "sharp-pilot.instructions.dotnet.codingStandards": {
          "type": "boolean",
          "default": true,
          "description": "Enable .NET coding standards (naming, validation, file organization, API design)."
        },
        "sharp-pilot.instructions.dotnet.dapper": {
          "type": "boolean",
          "default": true,
          "description": "Enable Dapper guidelines (connection management, parameterized queries, mapping, transactions, performance)."
        },
        "sharp-pilot.instructions.dotnet.debugging": {
          "type": "boolean",
          "default": true,
          "description": "Enable debugging and troubleshooting guidelines."
        },
        "sharp-pilot.instructions.dotnet.entityFrameworkCore": {
          "type": "boolean",
          "default": true,
          "description": "Enable Entity Framework Core guidelines (DbContext lifetime, querying, migrations, bulk operations)."
        },
        "sharp-pilot.instructions.dotnet.nuget": {
          "type": "boolean",
          "default": true,
          "description": "Enable NuGet package and dependency guidelines."
        },
        "sharp-pilot.instructions.dotnet.performanceMemory": {
          "type": "boolean",
          "default": true,
          "description": "Enable performance and memory optimization guidelines."
        },
        "sharp-pilot.instructions.dotnet.postgresql": {
          "type": "boolean",
          "default": true,
          "description": "Enable PostgreSQL guidelines (security, query design, performance, PL/pgSQL, schema migrations)."
        },
        "sharp-pilot.instructions.dotnet.razor": {
          "type": "boolean",
          "default": true,
          "description": "Enable Razor file structure and syntax guidelines."
        },
        "sharp-pilot.instructions.dotnet.sqlServer": {
          "type": "boolean",
          "default": true,
          "description": "Enable SQL Server guidelines (T-SQL security, query design, performance, stored procedures, schema migrations)."
        },
        "sharp-pilot.instructions.dotnet.testing": {
          "type": "boolean",
          "default": true,
          "description": "Enable general testing strategy guidelines (TDD, naming, organization)."
        },
        "sharp-pilot.instructions.dotnet.maui": {
          "type": "boolean",
          "default": true,
          "description": "Enable .NET MAUI guidelines (MVVM, Shell navigation, data binding, layouts, DI)."
        },
        "sharp-pilot.instructions.dotnet.mongodb": {
          "type": "boolean",
          "default": true,
          "description": "Enable MongoDB guidelines (security, data modelling, query design, indexing, transactions)."
        },
        "sharp-pilot.instructions.dotnet.mysql": {
          "type": "boolean",
          "default": true,
          "description": "Enable MySQL guidelines (security, query design, performance, stored procedures, schema migrations)."
        },
        "sharp-pilot.instructions.dotnet.oracle": {
          "type": "boolean",
          "default": true,
          "description": "Enable Oracle guidelines (security, query design, performance, PL/SQL, schema migrations)."
        },
        "sharp-pilot.instructions.dotnet.sqlite": {
          "type": "boolean",
          "default": true,
          "description": "Enable SQLite guidelines (security, query design, performance, WAL mode, schema migrations)."
        },
        "sharp-pilot.instructions.dotnet.unity": {
          "type": "boolean",
          "default": true,
          "description": "Enable Unity guidelines (MonoBehaviour lifecycle, component caching, physics, coroutines, ScriptableObjects, performance)."
        },
        "sharp-pilot.instructions.dotnet.winForms": {
          "type": "boolean",
          "default": true,
          "description": "Enable Windows Forms threading, data binding, layout, and lifecycle guidelines."
        },
        "sharp-pilot.instructions.dotnet.wpf": {
          "type": "boolean",
          "default": true,
          "description": "Enable WPF MVVM, data binding, threading, and performance guidelines."
        },
        "sharp-pilot.instructions.dotnet.xunit": {
          "type": "boolean",
          "default": true,
          "description": "Enable xUnit-specific guidelines (v3 APIs, attributes, assertions)."
        },
        "sharp-pilot.instructions.dotnet.csharp.codingStyle": {
          "type": "boolean",
          "default": true,
          "description": "Enable C# coding style rules (member ordering, formatting, etc.)."
        },
        "sharp-pilot.instructions.dotnet.fsharp.codingStyle": {
          "type": "boolean",
          "default": true,
          "description": "Enable F# coding style rules (module layout, naming, type design, pattern matching, formatting)."
        },
        "sharp-pilot.instructions.git.commitFormat": {
          "type": "boolean",
          "default": true,
          "description": "Enable Conventional Commits formatting guidelines."
        },
        "sharp-pilot.instructions.web.angular": {
          "type": "boolean",
          "default": true,
          "description": "Enable Angular guidelines (standalone components, signals, DI, RxJS, routing, reactive forms)."
        },
        "sharp-pilot.instructions.web.css": {
          "type": "boolean",
          "default": true,
          "description": "Enable CSS layout, theming, selectors, and accessibility guidelines."
        },
        "sharp-pilot.instructions.web.html": {
          "type": "boolean",
          "default": true,
          "description": "Enable HTML semantics, accessibility, and structure guidelines."
        },
        "sharp-pilot.instructions.web.javascript": {
          "type": "boolean",
          "default": true,
          "description": "Enable JavaScript language, async patterns, and security guidelines."
        },
        "sharp-pilot.instructions.web.react": {
          "type": "boolean",
          "default": true,
          "description": "Enable React component purity, Hooks, state design, effects, and list rendering guidelines."
        },
        "sharp-pilot.instructions.web.svelte": {
          "type": "boolean",
          "default": true,
          "description": "Enable Svelte guidelines (runes, stores, SvelteKit routing, load functions, form actions)."
        },
        "sharp-pilot.instructions.web.typescript": {
          "type": "boolean",
          "default": true,
          "description": "Enable TypeScript type safety, generics, and anti-pattern guidelines."
        },
        "sharp-pilot.instructions.web.vue": {
          "type": "boolean",
          "default": true,
          "description": "Enable Vue.js guidelines (Composition API, reactivity, Pinia, Vue Router, component design)."
        },
        "sharp-pilot.tools.check_csharp_async_patterns": {
          "type": "boolean",
          "default": true,
          "description": "Enable the async patterns checker tool."
        },
        "sharp-pilot.tools.check_csharp_coding_style": {
          "type": "boolean",
          "default": true,
          "description": "Enable the coding style checker tool."
        },
        "sharp-pilot.tools.check_csharp_member_ordering": {
          "type": "boolean",
          "default": true,
          "description": "Enable the member ordering checker tool."
        },
        "sharp-pilot.tools.check_csharp_naming_conventions": {
          "type": "boolean",
          "default": true,
          "description": "Enable the naming conventions checker tool."
        },
        "sharp-pilot.tools.check_csharp_nullable_context": {
          "type": "boolean",
          "default": true,
          "description": "Enable the nullable context checker tool."
        },
        "sharp-pilot.tools.check_csharp_project_structure": {
          "type": "boolean",
          "default": true,
          "description": "Enable the project structure checker tool."
        },
        "sharp-pilot.tools.check_csharp_test_style": {
          "type": "boolean",
          "default": true,
          "description": "Enable the test style checker tool."
        },
        "sharp-pilot.tools.check_nuget_hygiene": {
          "type": "boolean",
          "default": true,
          "description": "Enable the NuGet hygiene checker tool."
        },
        "sharp-pilot.tools.check_git_commit_content": {
          "type": "boolean",
          "default": true,
          "description": "Enable the commit content validator tool."
        },
        "sharp-pilot.tools.check_git_commit_format": {
          "type": "boolean",
          "default": true,
          "description": "Enable the commit format validator tool."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "publish:servers": "pwsh scripts/publish-servers.ps1",
    "package:win-x64": "pwsh scripts/publish-servers.ps1 -RuntimeIdentifier win-x64 -Package",
    "package:win-arm64": "pwsh scripts/publish-servers.ps1 -RuntimeIdentifier win-arm64 -Package",
    "package:linux-x64": "pwsh scripts/publish-servers.ps1 -RuntimeIdentifier linux-x64 -Package",
    "package:linux-arm64": "pwsh scripts/publish-servers.ps1 -RuntimeIdentifier linux-arm64 -Package",
    "package:osx-x64": "pwsh scripts/publish-servers.ps1 -RuntimeIdentifier osx-x64 -Package",
    "package:osx-arm64": "pwsh scripts/publish-servers.ps1 -RuntimeIdentifier osx-arm64 -Package",
    "package:all": "pwsh scripts/publish-servers.ps1 -All",
    "publish:all": "pwsh scripts/publish-servers.ps1 -Publish"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.99.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
