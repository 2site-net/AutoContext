{
  "name": "autocontext-worker-web",
  "version": "0.8.0",
  "type": "module",
  "private": true,
  "imports": {
    "#types/*.js": {
      "types": "./src/types/*.ts",
      "default": "./out/types/*.js"
    },
    "#testing/*": "./tests/testing/*",
    "#src/*": "./src/*"
  },
  "scripts": {
    "prebuild": "pwsh ../../versionize.ps1 Export src/version.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node out/index.js"
  },
  "dependencies": {
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "vitest": "^4.1.0"
  }
}
