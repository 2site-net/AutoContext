{
  "name": "autocontext",
  "displayName": "AutoContext",
  "description": "AutoContext is a context toolkit for AI coding assistants. It ships with curated instructions that shape how code is written and reviewed, bundled MCP tools that validate code against concrete rules, and a context orchestration layer that automatically wires the right guidance and checks into the model based on the workspace and environment.",
  "version": "0.5.0",
  "publisher": "2site-net",
  "license": "AGPL-3.0-only",
  "author": {
    "name": "Eyal Alon",
    "email": "autocontext@2site.net",
    "url": "https://github.com/iam3yal"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/2site-net/AutoContext"
  },
  "bugs": {
    "url": "https://github.com/2site-net/AutoContext/issues"
  },
  "icon": "resources/logo.png",
  "type": "module",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "AutoContextProvider",
        "label": "AutoContext Servers"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "AutoContext",
          "title": "AutoContext",
          "icon": "resources/logo_vscode.svg"
        }
      ]
    },
    "views": {
      "AutoContext": [
        {
          "id": "autocontext.instructions-view",
          "name": "Instructions",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "autocontext.mcp-tools-view",
          "name": "MCP Tools",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "commands": [
      {
        "command": "autocontext.auto-configure",
        "title": "Auto Configure",
        "category": "AutoContext"
      },
      {
        "command": "autocontext.toggle-instruction",
        "title": "Toggle Instruction",
        "category": "AutoContext"
      },
      {
        "command": "autocontext.reset-instructions",
        "title": "Reset Instructions",
        "category": "AutoContext"
      },
      {
        "command": "autocontext.enable-instruction",
        "title": "Enable Instruction",
        "category": "AutoContext",
        "icon": "$(check)"
      },
      {
        "command": "autocontext.disable-instruction",
        "title": "Disable Instruction",
        "category": "AutoContext",
        "icon": "$(close)"
      },
      {
        "command": "autocontext.enter-export-mode",
        "title": "Export Instructions",
        "category": "AutoContext",
        "icon": "$(export)"
      },
      {
        "command": "autocontext.confirm-export",
        "title": "Confirm Export",
        "category": "AutoContext",
        "icon": "$(check)"
      },
      {
        "command": "autocontext.cancel-export",
        "title": "Cancel Export",
        "category": "AutoContext",
        "icon": "$(close)"
      },
      {
        "command": "autocontext.delete-override",
        "title": "Delete Override",
        "category": "AutoContext",
        "icon": "$(trash)"
      },
      {
        "command": "autocontext.show-original",
        "title": "Show Original",
        "category": "AutoContext",
        "icon": "$(eye)"
      },
      {
        "command": "autocontext.show-not-detected",
        "title": "Show Not Detected",
        "category": "AutoContext",
        "icon": "$(eye)"
      },
      {
        "command": "autocontext.hide-not-detected",
        "title": "Hide Not Detected",
        "category": "AutoContext",
        "icon": "$(eye-closed)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "autocontext.toggle-instruction",
          "when": "false"
        },
        {
          "command": "autocontext.reset-instructions",
          "when": "false"
        },
        {
          "command": "autocontext.enable-instruction",
          "when": "false"
        },
        {
          "command": "autocontext.disable-instruction",
          "when": "false"
        },
        {
          "command": "autocontext.enter-export-mode",
          "when": "false"
        },
        {
          "command": "autocontext.confirm-export",
          "when": "false"
        },
        {
          "command": "autocontext.cancel-export",
          "when": "false"
        },
        {
          "command": "autocontext.delete-override",
          "when": "false"
        },
        {
          "command": "autocontext.show-original",
          "when": "false"
        },
        {
          "command": "autocontext.show-not-detected",
          "when": "false"
        },
        {
          "command": "autocontext.hide-not-detected",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "autocontext.hide-not-detected",
          "when": "(view == 'autocontext.instructions-view' || view == 'autocontext.mcp-tools-view') && autocontext.show-not-detected"
        },
        {
          "command": "autocontext.show-not-detected",
          "when": "(view == 'autocontext.instructions-view' || view == 'autocontext.mcp-tools-view') && !autocontext.show-not-detected"
        },
        {
          "command": "autocontext.enter-export-mode",
          "when": "view == 'autocontext.instructions-view' && !autocontext.export-mode",
          "group": "navigation@2"
        },
        {
          "command": "autocontext.confirm-export",
          "when": "view == 'autocontext.instructions-view' && autocontext.export-mode",
          "group": "navigation@2"
        },
        {
          "command": "autocontext.cancel-export",
          "when": "view == 'autocontext.instructions-view' && autocontext.export-mode",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "autocontext.enable-instruction",
          "when": "viewItem == 'instruction.disabled' && !autocontext.export-mode",
          "group": "inline"
        },
        {
          "command": "autocontext.disable-instruction",
          "when": "viewItem == 'instruction.enabled' && !autocontext.export-mode",
          "group": "inline"
        },
        {
          "command": "autocontext.show-original",
          "when": "viewItem == 'instruction.overridden' && !autocontext.export-mode",
          "group": "inline@1"
        },
        {
          "command": "autocontext.delete-override",
          "when": "viewItem == 'instruction.overridden' && !autocontext.export-mode",
          "group": "inline@2"
        }
      ]
    },
    "chatInstructions": [
      {
        "path": "./instructions/copilot.instructions.md"
      },
      {
        "path": "./instructions/.generated/code-review.instructions.md",
        "when": "config.autocontext.instructions.codeReview && !autocontext.override.codeReview"
      },
      {
        "path": "./instructions/.generated/design-principles.instructions.md",
        "when": "config.autocontext.instructions.designPrinciples && !autocontext.override.designPrinciples"
      },
      {
        "path": "./instructions/.generated/rest-api-design.instructions.md",
        "when": "config.autocontext.instructions.restApiDesign && !autocontext.override.restApiDesign"
      },
      {
        "path": "./instructions/.generated/testing.instructions.md",
        "when": "config.autocontext.instructions.testing && (autocontext.workspace.hasDotNetTesting || autocontext.workspace.hasWebTesting) && !autocontext.override.testing"
      },
      {
        "path": "./instructions/.generated/lang-bash.instructions.md",
        "when": "config.autocontext.instructions.lang.bash && autocontext.workspace.hasBash && !autocontext.override.lang.bash"
