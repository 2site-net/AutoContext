  "scripts": {
    "vscode:prepublish": "node -e \"if(!process.env.AUTOCONTEXT_VSCE_BYPASS){console.error('Do not run vsce package directly. Use: ./build.ps1 Package');process.exit(1)}\"",
    "compile": "pwsh ../../build.ps1 Compile TS",
    "watch": "tsc -watch -p ./tsconfig.build.json",
    "test": "pwsh ../../build.ps1 Test TS",
    "test:smoke": "npm run compile && tsc -p tests/smoke-tests/tsconfig.json && node -e \"require('fs').writeFileSync('dist/tests/smoke-tests/package.json','{\\\"type\\\":\\\"commonjs\\\"}')\" && node -e \"require('fs').mkdirSync('tests/workspaces/mixed/.git',{recursive:true})\" && vscode-test --config tests/.vscode-test.mjs"
  },
