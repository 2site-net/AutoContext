      {
        "id": "autocontext.get-started",
        "title": "Get Started with AutoContext",
        "description": "Learn how AutoContext enhances GitHub Copilot with curated instructions and MCP tools.",
        "steps": [
          {
            "id": "autocontext.welcome",
            "title": "Welcome to AutoContext",
            "description": "Discover how AutoContext elevates code quality with curated instructions and model-invokable tools.",
            "media": {
              "markdown": "walkthroughs/welcome.md"
            }
          },
          {
            "id": "autocontext.instructions",
            "title": "Chat Instructions",
            "description": "Enable instruction sets that guide Copilot's responses for your tech stack.\n[Open Instructions Panel](command:autocontext.instructions-view.focus)",
            "media": {
              "markdown": "walkthroughs/instructions.md"
            },
            "completionEvents": [
              "onView:autocontext.instructions-view"
            ]
          },
          {
            "id": "autocontext.mcp-tools",
            "title": "MCP Tools",
            "description": "Enable quality-assurance tools that Copilot can call in agent mode.\n[Open Tools Panel](command:autocontext.mcp-tools-view.focus)",
