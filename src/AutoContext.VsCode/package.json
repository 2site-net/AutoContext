{
  "name": "autocontext",
  "displayName": "AutoContext",
  "description": "AutoContext gives AI coding assistants the right context for your codebase. It provides built-in instructions, MCP tool checks, a dedicated tree view for managing them, and automatic context orchestration to deliver the right guidance and checks for the current task.",
  "version": "0.5.5",
  "publisher": "2site-net",
  "preview": true,
  "license": "AGPL-3.0-only",
  "author": {
    "name": "Eyal Alon",
    "email": "autocontext@2site.net",
    "url": "https://github.com/iam3yal"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/2site-net/AutoContext"
  },
  "bugs": {
    "url": "https://github.com/2site-net/AutoContext/issues"
  },
  "homepage": "https://github.com/2site-net/AutoContext#readme",
  "icon": "resources/logo.png",
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://vsmarketplacebadges.dev/version-short/2site-net.autocontext.png",
      "href": "https://marketplace.visualstudio.com/items?itemName=2site-net.autocontext",
      "description": "Marketplace version"
    },
    {
      "url": "https://vsmarketplacebadges.dev/installs-short/2site-net.autocontext.png",
      "href": "https://marketplace.visualstudio.com/items?itemName=2site-net.autocontext",
      "description": "Marketplace installs"
    },
    {
      "url": "https://vsmarketplacebadges.dev/rating-short/2site-net.autocontext.png",
      "href": "https://marketplace.visualstudio.com/items?itemName=2site-net.autocontext",
      "description": "Marketplace rating"
    },
    {
      "url": "https://github.com/2site-net/AutoContext/actions/workflows/ci.yml/badge.svg",
      "href": "https://github.com/2site-net/AutoContext/actions/workflows/ci.yml",
      "description": "CI status"
    }
  ],
  "type": "module",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "copilot",
    "copilot-instructions",
    "chat",
    "chat-instructions",
    "mcp",
    "mcp-server",
    "mcp-tools",
    "agent",
    "ai",
    "ai-instructions",
    "ai-context",
    "ai-assistant",
    "ai-agent",
    "coding",
    "coding-assistant",
    "vibe-coding",
    "linting",
    "dotnet",
    "csharp",
    "nodejs",
    "javascript",
    "typescript"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "AutoContextProvider",
        "label": "AutoContext Servers"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "AutoContext",
          "title": "AutoContext",
          "icon": "resources/logo_vscode.svg"
        }
      ]
    },
    "views": {
      "AutoContext": [
        {
          "id": "autocontext.instructions-view",
          "name": "Instructions",
          "icon": "$(note)",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "autocontext.mcp-tools-view",
          "name": "MCP Tools",
          "icon": "$(plug)",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "commands": [
      {
        "command": "autocontext.auto-configure",
        "title": "Auto Configure",
        "category": "AutoContext"
      },
      {
        "command": "autocontext.toggle-instruction",
        "title": "Toggle Instruction",
        "category": "AutoContext"
      },
      {
        "command": "autocontext.reset-instructions",
        "title": "Reset Instructions",
        "category": "AutoContext"
      },
      {
        "command": "autocontext.enable-instruction",
        "title": "Enable Instruction",
        "category": "AutoContext",
        "icon": "$(check)"
      },
      {
        "command": "autocontext.disable-instruction",
        "title": "Disable Instruction",
        "category": "AutoContext",
        "icon": "$(close)"
      },
      {
        "command": "autocontext.enter-export-mode",
        "title": "Export Instructions",
        "category": "AutoContext",
        "icon": "$(export)"
      },
      {
        "command": "autocontext.confirm-export",
        "title": "Confirm Export",
        "category": "AutoContext",
        "icon": "$(check)"
      },
      {
        "command": "autocontext.cancel-export",
        "title": "Cancel Export",
        "category": "AutoContext",
        "icon": "$(close)"
      },
      {
        "command": "autocontext.delete-override",
        "title": "Delete Override",
        "category": "AutoContext",
        "icon": "$(trash)"
      },
      {
        "command": "autocontext.show-original",
        "title": "Show Original",
        "category": "AutoContext",
        "icon": "$(eye)"
      },
      {
        "command": "autocontext.show-changelog",
        "title": "Show Changelog",
        "category": "AutoContext",
        "icon": "$(book)"
      },
      {
        "command": "autocontext.show-whats-new",
        "title": "What's New",
        "category": "AutoContext"
      },
      {
        "command": "autocontext.show-not-detected",
        "title": "Show Not Detected",
        "category": "AutoContext",
        "icon": "$(eye)"
      },
      {
        "command": "autocontext.hide-not-detected",
        "title": "Hide Not Detected",
        "category": "AutoContext",
        "icon": "$(eye-closed)"
      },
      {
        "command": "autocontext.start-mcp-server",
        "title": "Start Server",
        "category": "AutoContext",
        "icon": "$(play)"
      },
      {
        "command": "autocontext.stop-mcp-server",
        "title": "Stop Server",
        "category": "AutoContext",
        "icon": "$(debug-stop)"
      },
      {
        "command": "autocontext.restart-mcp-server",
        "title": "Restart Server",
        "category": "AutoContext",
        "icon": "$(debug-restart)"
      },
      {
        "command": "autocontext.show-mcp-server-output",
        "title": "Show Output",
        "category": "AutoContext",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "autocontext.toggle-instruction",
          "when": "false"
        },
        {
          "command": "autocontext.reset-instructions",
          "when": "false"
        },
        {
          "command": "autocontext.enable-instruction",
          "when": "false"
        },
        {
          "command": "autocontext.disable-instruction",
          "when": "false"
        },
        {
          "command": "autocontext.enter-export-mode",
          "when": "false"
        },
        {
          "command": "autocontext.confirm-export",
          "when": "false"
        },
        {
          "command": "autocontext.cancel-export",
          "when": "false"
        },
        {
          "command": "autocontext.delete-override",
          "when": "false"
        },
        {
          "command": "autocontext.show-original",
          "when": "false"
        },
        {
          "command": "autocontext.show-changelog",
          "when": "false"
        },
        {
          "command": "autocontext.show-whats-new",
          "when": "autocontext.has-whats-new"
        },
        {
          "command": "autocontext.show-not-detected",
          "when": "false"
        },
        {
          "command": "autocontext.hide-not-detected",
          "when": "false"
        },
        {
          "command": "autocontext.start-mcp-server",
          "when": "false"
        },
        {
          "command": "autocontext.stop-mcp-server",
          "when": "false"
        },
        {
          "command": "autocontext.restart-mcp-server",
          "when": "false"
        },
        {
          "command": "autocontext.show-mcp-server-output",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "autocontext.hide-not-detected",
          "when": "(view == 'autocontext.instructions-view' || view == 'autocontext.mcp-tools-view') && autocontext.show-not-detected"
        },
        {
          "command": "autocontext.show-not-detected",
          "when": "(view == 'autocontext.instructions-view' || view == 'autocontext.mcp-tools-view') && !autocontext.show-not-detected"
        },
        {
          "command": "autocontext.enter-export-mode",
          "when": "view == 'autocontext.instructions-view' && !autocontext.export-mode",
          "group": "navigation@2"
        },
        {
          "command": "autocontext.confirm-export",
          "when": "view == 'autocontext.instructions-view' && autocontext.export-mode",
          "group": "navigation@2"
        },
        {
          "command": "autocontext.cancel-export",
          "when": "view == 'autocontext.instructions-view' && autocontext.export-mode",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "autocontext.enable-instruction",
          "when": "viewItem =~ /^instruction\\.disabled/ && !autocontext.export-mode",
          "group": "inline"
        },
        {
          "command": "autocontext.disable-instruction",
          "when": "viewItem =~ /^instruction\\.enabled/ && !autocontext.export-mode",
          "group": "inline"
        },
        {
          "command": "autocontext.show-original",
          "when": "viewItem =~ /^instruction\\.overridden/ && !autocontext.export-mode",
          "group": "inline@1"
        },
        {
          "command": "autocontext.delete-override",
          "when": "viewItem =~ /^instruction\\.overridden/ && !autocontext.export-mode",
          "group": "inline@2"
        },
        {
          "command": "autocontext.show-changelog",
          "when": "viewItem =~ /\\.hasChangelog/ && !autocontext.export-mode",
          "group": "inline@3"
        },
        {
          "command": "autocontext.start-mcp-server",
          "when": "view == 'autocontext.mcp-tools-view' && viewItem == 'serverNode.stopped'",
          "group": "inline@1"
        },
        {
          "command": "autocontext.stop-mcp-server",
          "when": "view == 'autocontext.mcp-tools-view' && viewItem =~ /^serverNode\\.(running|partial)$/",
          "group": "inline@2"
        },
        {
          "command": "autocontext.restart-mcp-server",
          "when": "view == 'autocontext.mcp-tools-view' && viewItem =~ /^serverNode\\.(running|partial)$/",
          "group": "inline@3"
        },
        {
          "command": "autocontext.show-mcp-server-output",
          "when": "view == 'autocontext.mcp-tools-view' && viewItem =~ /^serverNode\\.(running|partial|stopped)$/",
          "group": "inline@4"
        }
      ]
    },
    "chatInstructions": [
      {
        "path": "./instructions/copilot.instructions.md"
      },
